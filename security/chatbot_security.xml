<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════════
         Security Groups
         ═══════════════════════════════════════════════════════════ -->
    <record id="module_category_chatbot" model="ir.module.category">
        <field name="name">AI Chatbot</field>
        <field name="description">Perfect HR AI Chatbot management</field>
        <field name="sequence">100</field>
    </record>

    <record id="group_chatbot_user" model="res.groups">
        <field name="name">Chatbot User</field>
        <field name="category_id" ref="module_category_chatbot"/>
        <field name="comment">
            Can view chat sessions assigned to them and basic analytics.
        </field>
    </record>

    <record id="group_chatbot_admin" model="res.groups">
        <field name="name">Chatbot Administrator</field>
        <field name="category_id" ref="module_category_chatbot"/>
        <field name="implied_ids" eval="[(4, ref('group_chatbot_user'))]"/>
        <field name="comment">
            Full access: manage knowledge base, view all sessions,
            configure AI settings, and access analytics.
        </field>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

    <!-- ═══════════════════════════════════════════════════════════
         Record Rules
         ═══════════════════════════════════════════════════════════ -->

    <!-- Admin: full access to all sessions -->
    <record id="rule_session_admin" model="ir.rule">
        <field name="name">Chatbot Session: Admin (all)</field>
        <field name="model_id" ref="model_perfecthr_chatbot_session"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_chatbot_admin'))]"/>
    </record>

    <!-- Admin: full access to knowledge base -->
    <record id="rule_knowledge_admin" model="ir.rule">
        <field name="name">Chatbot Knowledge: Admin (all)</field>
        <field name="model_id" ref="model_perfecthr_chatbot_knowledge"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_chatbot_admin'))]"/>
    </record>

    <!-- Admin: full access to analytics -->
    <record id="rule_analytics_admin" model="ir.rule">
        <field name="name">Chatbot Analytics: Admin (all)</field>
        <field name="model_id" ref="model_perfecthr_chatbot_analytics"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_chatbot_admin'))]"/>
    </record>

</odoo>
